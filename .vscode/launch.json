{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32 (OpenOCD)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/STM_freertos_szklarania.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "openocd",
            "configFiles": [
                "board/st_nucleo_f0.cfg"
            ],
            "gdbPath": "/usr/bin/gdb-multiarch",
            "preLaunchTask": "CMake: build"
        }
    ]
}